# Copy to .env.local and fill in: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (optional unless you use admin API / dev bypass)
SUPABASE_SERVICE_ROLE_KEY=

# Optional app URL (defaults to request origin in some routes)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional access control (see README or auth callback)
ADMIN_EMAIL=
ALLOWED_EMAILS=
